{
  "name": "zdn-notes",
  "version": "1.1.1",
  "description": "",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-vite build && electron-builder --win --dir",
    "dist": "electron-vite build && electron-builder --win",
    "dist:ci": "electron-vite build && electron-builder --win --publish=never",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "build": {
    "appId": "com.zdn.notes",
    "productName": "ZDNotes",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "ZDNotes-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "z-dn",
      "repo": "zdn-notes"
    }
  },
  "keywords": [],
  "author": "zdn",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@milkdown/core": "^7.21.2",
    "@milkdown/plugin-listener": "^7.21.2",
    "@milkdown/preset-commonmark": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "chrono-node": "^2.9.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.9",
    "marked": "^15.0.12",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.22.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
